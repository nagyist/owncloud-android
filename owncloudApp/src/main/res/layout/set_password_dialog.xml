<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minWidth="275dp"
    android:orientation="vertical"
    android:padding="@dimen/standard_half_margin">

    <TextView
        android:id="@+id/set_password_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/standard_half_padding"
        android:text="@string/public_link_set_password"
        android:textAppearance="@android:style/TextAppearance.Material.DialogWindowTitle"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/password_input_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/standard_half_margin"
                android:layout_marginEnd="@dimen/standard_half_padding"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/password_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textSize="15sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/password_generator_buttons_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/generate_password_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/share_via_link_generate_password_button"
                    android:textColor="@color/primary_button_background_color"
                    android:contentDescription="@string/content_description_generate_password_button"
                    style="?android:attr/borderlessButtonStyle"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/copy_password_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/share_via_link_copy_password_button"
                    android:enabled="false"
                    android:contentDescription="@string/content_description_copy_password_button"
                    style="?android:attr/borderlessButtonStyle" />

            </LinearLayout>

            <TextView
                android:id="@+id/password_policy_intro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/standard_half_margin"
                android:layout_marginEnd="@dimen/standard_half_margin"
                android:layout_marginTop="@dimen/standard_half_margin"
                android:text="@string/password_policy_intro"/>

            <include
                layout="@layout/password_policy_requirement"
                android:id="@+id/password_policy_min_characters"/>

            <include
                layout="@layout/password_policy_requirement"
                android:id="@+id/password_policy_upper_characters"/>

            <include
                layout="@layout/password_policy_requirement"
                android:id="@+id/password_policy_lower_case_characters"/>

            <include
                layout="@layout/password_policy_requirement"
                android:id="@+id/password_policy_min_special_characters"/>

            <include
                layout="@layout/password_policy_requirement"
                android:id="@+id/password_policy_max_characters"/>

            <include
                layout="@layout/password_policy_requirement"
                android:id="@+id/password_policy_min_digits"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/standard_margin"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/cancel_password_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@android:string/cancel"
                    android:textColor="@color/primary_button_background_color"
                    android:contentDescription="@string/content_description_cancel_button"
                    style="?android:attr/borderlessButtonStyle"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/set_password_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/common_set"
                    android:contentDescription="@string/content_description_set_button"
                    android:enabled="false"
                    style="?android:attr/borderlessButtonStyle"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
